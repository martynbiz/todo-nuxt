# Port the app is exposed on (default: 3000)
APP_PORT=3000

# PostgreSQL credentials
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban
POSTGRES_DB=kanban

# Dev only — Nuxt server connects to the database directly
DATABASE_URL=postgresql://kanban:kanban@localhost:5432/kanban

# Microsoft Entra ID app registration
NUXT_OAUTH_MICROSOFT_CLIENT_ID=<your-client-id>
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET=<your-client-secret>
NUXT_OAUTH_MICROSOFT_TENANT=<your-tenant-id>   # or "common" for multi-tenant

# Session cookie encryption (generate a random 32+ char string)
NUXT_SESSION_PASSWORD=<random-32-char-string>

OPENAI_API_KEY=sk-...